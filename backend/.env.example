# Runtime
NODE_ENV="development"
PORT=5000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/irri_website?schema=public"

# Auth
# Use a long random value in production.
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Frontend origin allowed by CORS
FRONTEND_URL="http://localhost:3000"

# Optional media provider credentials
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Seed admin account
# Change these before using a real production database.
SEED_ADMIN_NAME="Super Admin"
SEED_ADMIN_EMAIL="admin@irri.edu.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
