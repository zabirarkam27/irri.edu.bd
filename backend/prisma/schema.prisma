generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  MODERATOR
}

enum Status {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PersonType {
  ADMINISTRATION
  FACULTY
  STAFF
  RESEARCHER
}

enum MediaType {
  IMAGE
  DOCUMENT
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         Role        @default(EDITOR)
  isActive     Boolean     @default(true)
  mediaAssets  MediaAsset[]
  auditLogs    AuditLog[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([role])
}

model InstitutionProfile {
  id             String   @id @default(cuid())
  name           String
  nameBn         String?
  acronym        String
  location       String
  motto          String?
  mottoBn        String?
  mission        String
  missionBn      String?
  vision         String
  visionBn       String?
  establishedAt  Int?
  operationStart Int?
  domain         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Page {
  id              String   @id @default(cuid())
  title           String
  titleBn         String?
  slug            String   @unique
  content         String
  contentBn       String?
  excerpt         String?
  status          Status   @default(DRAFT)
  seoTitle        String?
  metaDescription String?
  ogImage         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Person {
  id          String     @id @default(cuid())
  name        String
  nameBn      String?
  slug        String     @unique
  designation String
  bio         String?
  photoUrl    String?
  order       Int        @default(0)
  type        PersonType @default(ADMINISTRATION)
  status      Status     @default(PUBLISHED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([type, status])
}

model Department {
  id          String    @id @default(cuid())
  name        String
  nameBn      String?
  slug        String    @unique
  description String?
  status      Status    @default(DRAFT)
  programs    Program[]
  courses     Course[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Program {
  id           String      @id @default(cuid())
  title        String
  titleBn      String?
  slug         String      @unique
  level        String
  duration     String?
  description  String?
  status       Status      @default(DRAFT)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  courses      Course[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
}

model Course {
  id           String      @id @default(cuid())
  title        String
  titleBn      String?
  slug         String      @unique
  code         String?
  credits      Float?
  description  String?
  status       Status      @default(DRAFT)
  programId    String?
  program      Program?    @relation(fields: [programId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model NewsPost {
  id              String   @id @default(cuid())
  title           String
  titleBn         String?
  slug            String   @unique
  excerpt         String?
  content         String
  contentBn       String?
  status          Status   @default(DRAFT)
  publishedAt     DateTime?
  seoTitle        String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, publishedAt])
}

model Notice {
  id              String   @id @default(cuid())
  title           String
  titleBn         String?
  slug            String   @unique
  content         String
  contentBn       String?
  status          Status   @default(DRAFT)
  publishedAt     DateTime?
  seoTitle        String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, publishedAt])
}

model Event {
  id              String   @id @default(cuid())
  title           String
  titleBn         String?
  slug            String   @unique
  content         String
  contentBn       String?
  venue           String?
  startsAt        DateTime
  endsAt          DateTime?
  status          Status   @default(DRAFT)
  seoTitle        String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, startsAt])
}

model GalleryAlbum {
  id          String         @id @default(cuid())
  title       String
  titleBn     String?
  slug        String         @unique
  description String?
  status      Status         @default(DRAFT)
  images      GalleryImage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model GalleryImage {
  id        String       @id @default(cuid())
  albumId   String
  album     GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  url       String
  altText   String
  caption   String?
  order     Int          @default(0)
  createdAt DateTime     @default(now())
}

model Publication {
  id              String   @id @default(cuid())
  title           String
  titleBn         String?
  slug            String   @unique
  abstract        String?
  author          String?
  fileUrl         String?
  status          Status   @default(DRAFT)
  publishedAt     DateTime?
  seoTitle        String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
}

model MediaAsset {
  id         String    @id @default(cuid())
  url        String
  filename   String
  mimeType   String
  size       Int
  type       MediaType
  altText    String?
  uploadedBy String?
  uploader   User?     @relation(fields: [uploadedBy], references: [id])
  createdAt  DateTime  @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([entity, createdAt])
}
